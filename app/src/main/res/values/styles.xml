<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Dialog Buttons -->
    <style name="ConfirmationButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_height">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:ellipsize">end</item>
        <item name="android:singleLine">true</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="backgroundTint">@null</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="android:background">@drawable/button_primary_bg</item>
    </style>

    <style name="ConfirmationNeutralButton" parent="ActionButton">
        <item name="android:background">@drawable/button_primary_bg</item>
        <item name="android:textColor">@color/button_text</item>
    </style>

    <!-- Quiz Antwort Buttons -->
    <style name="AnswerButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_height">52dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:singleLine">false</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:autoSizeMinTextSize">10sp</item>
        <item name="android:autoSizeMaxTextSize">14sp</item>
        <item name="android:autoSizeStepGranularity">1sp</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="backgroundTint">@null</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:background">@drawable/button_answer_bg</item>
        <item name="android:textColor">@color/button_text</item>
    </style>

    <!-- richtig falsch Markierungen für Antworten für mehr Barrierefreiheit -->
    <style name="AnswerMarker">
        <item name="android:layout_width">16dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/button_signal_text</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Aktionsbutton Vorlage für Navi und Menübuttons -->
    <style name="ActionButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">160dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:ellipsize">end</item>
        <item name="android:singleLine">true</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:autoSizeMinTextSize">10sp</item>
        <item name="android:autoSizeMaxTextSize">14sp</item>
        <item name="android:autoSizeStepGranularity">1sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:stateListAnimator">@null</item>
        <!-- Wichtig bei eigenen Drawable-Backgrounds damit nicht von parentTints überschrieben -->
        <item name="backgroundTint">@null</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="android:background">@drawable/button_primary_bg</item>
    </style>

    <!-- Primärbutton wird im Moment für die meisten Buttons genutzt -->
    <style name="PrimaryButton" parent="ActionButton">
        <item name="android:background">@drawable/button_primary_bg</item>
        <item name="android:textColor">@color/button_text</item>
    </style>

    <!-- Optionstoggles - vorläuftig zusammengeklebt aus 2 Primärbuttons und angepasst -->
    <style name="ToggleLeftButton" parent="ActionButton">
        <item name="android:background">@drawable/toggle_left_bg</item>
        <item name="android:textColor">@color/button_text</item>
    </style>

    <style name="ToggleRightButton" parent="ActionButton">
        <item name="android:background">@drawable/toggle_right_bg</item>
        <item name="android:textColor">@color/button_text</item>
    </style>

</resources>