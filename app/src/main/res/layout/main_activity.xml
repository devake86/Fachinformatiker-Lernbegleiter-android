<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Statusbar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:id="@+id/placeholder1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:text="" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/versionIdText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="beta2"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"
            android:maxLines="1"
            android:ellipsize="end" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/placeholder2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:text="" />
    </LinearLayout>

    <!-- Content (füllt Rest) -->
    <LinearLayout
        android:id="@+id/menuContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- MenuPane (groß) -->
        <LinearLayout
            android:id="@+id/menuPane"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- TitleBox -->
            <LinearLayout
                android:id="@+id/menuTextBox"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.75"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FIQA"
                    android:textSize="64sp"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="32sp"
                    android:autoSizeMaxTextSize="64sp"
                    android:autoSizeStepGranularity="2sp" />
            </LinearLayout>

            <!-- FlavorBox -->
            <LinearLayout
                android:id="@+id/flavorTextBox"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.25"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/flavorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(Fach-)Informatiker&#10;Questions &amp; Answers"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:alpha="0.8"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

        </LinearLayout>

        <!-- InteractionPane -->
        <LinearLayout
            android:id="@+id/interactionBox"
            android:layout_width="match_parent"
            android:layout_height="248dp"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/ap1Button"
                style="@style/ActionButton"
                android:layout_width="174dp"
                android:layout_height="wrap_content"
                android:text="AP1 PoC (DummyQ)" />

            <Button
                android:id="@+id/start20QuestionsButton"
                style="@style/ActionButton"
                android:layout_width="174dp"
                android:layout_height="wrap_content"
                android:text="LF-VT1" />

            <Button
                android:id="@+id/startABKZButton"
                style="@style/ActionButton"
                android:layout_width="174dp"
                android:layout_height="wrap_content"
                android:text="VT1 Abkürzungen" />

            <Button
                android:id="@+id/startFBEGButton"
                style="@style/ActionButton"
                android:layout_width="174dp"
                android:layout_height="wrap_content"
                android:text="VT1 Fachbegriffe" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/exitButton"
                style="@style/ActionButton"
                android:layout_width="174dp"
                android:layout_height="wrap_content"
                android:text="Beenden" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

        <!-- Actionbar -->
        <LinearLayout
            android:id="@+id/actionBox"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- ActionButton -->
            <Button
                android:id="@+id/actionButton"
                style="@style/ActionButton"
                android:layout_width="174dp"
                android:layout_height="wrap_content"
                android:text="Bestätigen"
                android:visibility="invisible" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>