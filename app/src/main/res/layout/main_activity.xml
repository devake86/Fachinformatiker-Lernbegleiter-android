<?xml version="1.0" encoding="utf-8"?>
<!-- MainActivity -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="?attr/colorPrimary">

    <!-- Statusbar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start|center_vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/versionIdText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0-rc1"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="0dp"
        android:paddingBottom="8dp">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:id="@+id/menuContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp">

        <!-- MenuPane -->
        <LinearLayout
            android:id="@+id/menuPane"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- TitleBox -->
            <LinearLayout
                android:id="@+id/menuTextBox"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.75"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fachinformatiker\nLernbegleiter"
                    android:textStyle="bold"
                    android:textSize="64sp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="32sp"
                    android:autoSizeMaxTextSize="64sp"
                    android:autoSizeStepGranularity="2sp" />
            </LinearLayout>

            <!-- FlavorBox -->
            <LinearLayout
                android:id="@+id/flavorTextBox"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.25"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/flavorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile Lernergänzung zur Prüfungsvorbereitung für angehende Fachinformatiker"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

        </LinearLayout>

        <!-- InteractionPane -->
        <LinearLayout
            android:id="@+id/interactionBox"
            android:layout_width="match_parent"
            android:layout_height="264dp"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" >

            <Button
                android:id="@+id/quizChoiceButton"
                style="@style/PrimaryButton"
                android:layout_width="244dp"
                android:text="Quiz Auswahl"
                android:layout_marginBottom="4dp" />

            <Button
                android:id="@+id/startWithLastQuizDataButton"
                style="@style/PrimaryButton"
                android:layout_width="244dp"
                android:text="Letzte Auswahl"
                android:layout_marginBottom="4dp"
                android:visibility="invisible" />

            <Button
                android:id="@+id/errorTrainingButton"
                style="@style/PrimaryButton"
                android:layout_width="244dp"
                android:text="Fehlertraining"
                android:layout_marginBottom="4dp"
                android:visibility="invisible" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/optionsButton"
                style="@style/PrimaryButton"
                android:layout_width="244dp"
                android:text="Optionen"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="196dp"
                android:layout_height="30dp"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/leftHandedSelectButton"
                    style="@style/ToggleLeftButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="Linkshänder"
                    android:stateListAnimator="@null"
                    android:background="@drawable/toggle_left_bg"
                    android:visibility="invisible" />

                <Button
                    android:id="@+id/rightHandedSelectButton"
                    style="@style/ToggleRightButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="Rechtshänder"
                    android:stateListAnimator="@null"
                    android:background="@drawable/toggle_right_bg"
                    android:visibility="invisible" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="196dp"
                android:layout_height="30dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/lightModeSelectButton"
                    style="@style/ToggleLeftButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="Helle UI"
                    android:stateListAnimator="@null"
                    android:background="@drawable/toggle_left_bg"
                    android:visibility="invisible" />

                <Button
                    android:id="@+id/darkModeSelectButton"
                    style="@style/ToggleRightButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="Dunkle UI"
                    android:stateListAnimator="@null"
                    android:background="@drawable/toggle_right_bg"
                    android:visibility="invisible" />

            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

        <!-- Actionbar -->
        <LinearLayout
            android:id="@+id/actionBox"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <!-- ActionButton -->
            <Button
                android:id="@+id/actionButton"
                style="@style/PrimaryButton"
                android:layout_height="56dp"
                android:text="Beenden"
                android:visibility="invisible" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>