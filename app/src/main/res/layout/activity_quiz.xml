<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Status Bar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Frage X/Y -->
        <TextView
            android:id="@+id/questionCounterText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frage 00 / 00"
            android:textSize="14sp" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Frage ID -->
        <TextView
            android:id="@+id/questionIdText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LF00-0000"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Frage Box – 464dp -->
    <LinearLayout
        android:id="@+id/questionBox"
        android:layout_width="match_parent"
        android:layout_height="464dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- Text Box – 82dp -->
        <LinearLayout
            android:id="@+id/questionTextBox"
            android:layout_width="match_parent"
            android:layout_height="82dp"
            android:gravity="center">

            <TextView
                android:id="@+id/questionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAlignment="center"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Bild Box – 360dp -->
        <FrameLayout
            android:id="@+id/questionImageBox"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_gravity="center_horizontal">

            <ImageView
                android:id="@+id/questionImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:visibility="gone" />
        </FrameLayout>

    </LinearLayout>

    <!-- Interaktions Box – 0dp 1weight; passt sich an Restraum an -->
    <LinearLayout
        android:id="@+id/interactionBox"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/answersBox"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/evaluationBox"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:visibility="gone">

            <!-- Ergebnis: + RICHTIG + / - FALSCH - -->
            <TextView
                android:id="@+id/resultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAlignment="center"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Erklärungstext -->
            <TextView
                android:id="@+id/explanationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAlignment="center"
                android:textSize="20sp"
                android:padding="16dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Action Box – 70dp -->
    <LinearLayout
        android:id="@+id/actionBox"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="24dp" />

</LinearLayout>