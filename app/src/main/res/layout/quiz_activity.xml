<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Statusbar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:id="@+id/questionCounterText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/quizModeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/questionIdText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Content (füllt Rest) -->
    <LinearLayout
        android:id="@+id/quizContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- QuestionPane -->
        <LinearLayout
            android:id="@+id/questionBox"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- QuestionTextBox (groß, links/top wie Desktop) -->
            <LinearLayout
                android:id="@+id/questionTextBox"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.75"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/questionText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="start|center_vertical"
                    android:textAlignment="viewStart"
                    android:textSize="16sp"
                    android:visibility="gone"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="12sp"
                    android:autoSizeMaxTextSize="16sp"
                    android:autoSizeStepGranularity="1sp" />

                <TextView
                    android:id="@+id/resultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:textSize="32sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ExplanationBox (fix 120dp, Platz reserviert -> invisible statt gone) -->
            <LinearLayout
                android:id="@+id/explanationBox"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.25"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp"
                android:visibility="invisible">

                <TextView
                    android:id="@+id/explanationText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="start|center_vertical"
                    android:textAlignment="viewStart"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:alpha="0.8"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeMaxTextSize="14sp"
                    android:autoSizeStepGranularity="1sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- InteractionPane -->
        <LinearLayout
            android:id="@+id/interactionBox"
            android:layout_width="match_parent"
            android:layout_height="248dp"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- AnswersBox füllt den Bereich, sodass 2-4 Buttons reinpassen -->
            <LinearLayout
                android:id="@+id/answersBox"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="top|center_horizontal" />

            <Button
                android:id="@+id/newRoundButton"
                style="@style/ActionButton"
                android:layout_width="174dp"
                android:layout_height="wrap_content"
                android:text="Neue Runde"
                android:visibility="gone" />

            <Button
                android:id="@+id/menuButton"
                style="@style/ActionButton"
                android:layout_width="174dp"
                android:layout_height="wrap_content"
                android:text="Hauptmenü"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Actionbar -->
        <LinearLayout
            android:id="@+id/actionBox"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- ActionButton -->
            <Button
                android:id="@+id/actionButton"
                style="@style/ActionButton"
                android:layout_width="174dp"
                android:layout_height="wrap_content"
                android:text="Bestätigen"
                android:visibility="invisible"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>